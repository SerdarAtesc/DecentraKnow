PORT=4021
# OpenZeppelin testnet facilitator (free key via: curl https://channels.openzeppelin.com/testnet/gen)
FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
FACILITATOR_API_KEY=your-testnet-key
# Stellar G-account that receives USDC (needs a USDC trustline). Defaults to the platform account.
PAYTO=G...
PRICE=$0.01
NETWORK=stellar:testnet
FASTAPI_URL=http://localhost:8000
# Must match backend/.env X402_INTERNAL_SECRET
X402_INTERNAL_SECRET=dk-x402-secret-2026
